# Variables de entorno para PRODUCCIÓN (este archivo es solo documentación;
# no se carga automáticamente). En local con XAMPP no hace falta nada de esto:
# la app usa los valores por defecto y los archivos de config locales.

# --- Base de datos (MySQL externo, p. ej. TiDB Cloud o Aiven) ---
DB_HOST=tu-host-mysql
DB_PORT=4000
DB_USER=tu-usuario
DB_PASS=tu-password
DB_NAME=fruteria_madrid
# Conexión cifrada (los hosts gratuitos la exigen):
DB_SSL=1
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# --- Stripe (claves de PRUEBA) ---
STRIPE_SECRET=sk_test_xxx
STRIPE_PUBLISHABLE=pk_test_xxx
# URL pública de tu app (sin barra final):
STRIPE_DOMAIN=https://tu-app.onrender.com

# --- Firebase Admin ---
# Pega el JSON COMPLETO de la cuenta de servicio en UNA sola línea:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}
